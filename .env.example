# DeepShield Unified - Example Environment Variables

# Comma-separated list of allowed origins for CORS in production
# Example: https://yourdomain.com,https://app.yourdomain.com
DEEPSHIELD_ALLOWED_ORIGINS=*

# Flask server binding options
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Extension: Set this value from the extension using chrome.storage.local
# Key: deepshield_api_base
# Value example: https://api.yourdomain.com
